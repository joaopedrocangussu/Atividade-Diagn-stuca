using System;

class matriz
{
    static void Main()
    {
        Console.Write("*Digite o numero inicial: ");
        int inicial = int.Parse(Console.ReadLine());

        Console.Write("*Digite o numero final: ");
        int final = int.Parse(Console.ReadLine());

        if (inicial < final)
        {
            Console.WriteLine("*Numeros no intervalo:");

            for (int i = inicial; i <= final; i++)
            {
                Console.WriteLine(i);
            }
        }
        else
        {
            Console.WriteLine("O numero inicial deve ser menor que o numero final.");
        }
    }
}
